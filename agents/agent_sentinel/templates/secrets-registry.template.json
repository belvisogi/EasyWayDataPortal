{
  "version": "1.0.0",
  "description": "PAT & API key metadata registry. NO secret values — only identity, scope, and expiry dates.",
  "instructions": "Copy to /opt/easyway/secrets-registry.json (server) or C:\\old\\secrets-registry.json (dev). Fill in real dates. chmod 600.",
  "pats": [
    {
      "env_var": "AZURE_DEVOPS_EXT_PAT",
      "account": "ew-svc-azuredevops-agent",
      "scope": "Code R/W",
      "created": "YYYY-MM-DD",
      "expires": "YYYY-MM-DD",
      "rotation_days": 90
    },
    {
      "env_var": "ADO_PR_CREATOR_PAT",
      "account": "ew-svc-pr-creator",
      "scope": "PR Contribute",
      "created": "YYYY-MM-DD",
      "expires": "YYYY-MM-DD",
      "rotation_days": 90
    },
    {
      "env_var": "ADO_WORKITEMS_PAT",
      "account": "scrum-master",
      "scope": "Work Items R/W",
      "created": "YYYY-MM-DD",
      "expires": "YYYY-MM-DD",
      "rotation_days": 90
    }
  ],
  "api_keys": [
    {
      "env_var": "QDRANT_API_KEY",
      "service": "Qdrant",
      "location": "/opt/easyway/.env.secrets",
      "rotation_required": false,
      "last_rotated": "YYYY-MM-DD"
    },
    {
      "env_var": "DEEPSEEK_API_KEY",
      "service": "DeepSeek",
      "location": "/opt/easyway/.env.secrets",
      "rotation_required": false,
      "last_rotated": "YYYY-MM-DD"
    },
    {
      "env_var": "GITEA_API_TOKEN",
      "service": "Gitea",
      "location": "/opt/easyway/.env.secrets",
      "rotation_required": false,
      "last_rotated": "YYYY-MM-DD"
    }
  ]
}
